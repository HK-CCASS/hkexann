# HKEX公告系统环境变量配置文件
# 请复制此文件为 .env 并设置实际值
# 注意：请不要将包含真实密钥的 .env 文件提交到版本控制系统

# ============================================
# SiliconFlow API 配置（必需）
# ============================================

# SiliconFlow API
# =================

# SiliconFlow API访问密钥，用于LLM和嵌入模型服务 （必需）
# 示例值: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SILICONFLOW_API_KEY=

# SiliconFlow API基础URL （可选）
# 示例值: https://api.siliconflow.cn/v1
# SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1


# ClickHouse 数据库
# ================

# ClickHouse数据库主机地址 （推荐）
# 示例值: localhost
# CLICKHOUSE_HOST=localhost

# ClickHouse数据库密码 （必需）
# 示例值: your-secure-password
CLICKHOUSE_PASSWORD=


# CCASS 数据库
# ===========

# CCASS数据库主机地址 （推荐）
# 示例值: 192.168.6.207
# CCASS_HOST=192.168.6.207

# CCASS数据库密码 （必需）
# 示例值: your-ccass-password
CCASS_PASSWORD=


# MySQL 数据库
# ===========

# MySQL数据库密码（用于config.yaml） （推荐）
# 示例值: your-mysql-password
# DB_PASSWORD=your-mysql-password


# Milvus 向量数据库
# ==============

# Milvus向量数据库主机地址 （可选）
# 示例值: localhost
# MILVUS_HOST=localhost

# Milvus数据库密码（如果启用认证） （可选）
# 示例值: milvus-password
# MILVUS_PASSWORD=milvus-password


# Redis 缓存
# ==========

# Redis数据库密码（如果启用认证） （可选）
# 示例值: redis-password
# REDIS_PASSWORD=redis-password


# 系统配置
# ======

# 系统日志级别 （可选）
# 示例值: INFO
# LOG_LEVEL=INFO

# API服务器端口 （可选）
# 示例值: 8168
# API_PORT=8168


# ============================================
# 使用说明
# ============================================
#
# 1. 将此文件复制为 .env：cp .env.template .env
# 2. 编辑 .env 文件，设置实际的密钥和密码
# 3. 确保 .env 文件在 .gitignore 中，避免泄露敏感信息
# 4. 在生产环境中，建议使用密钥管理服务而非 .env 文件
#
# 安全提醒：
# - 使用强密码（至少8位，包含大小写字母、数字和特殊字符）
# - 定期轮换API密钥和数据库密码
# - 不要在代码中硬编码敏感信息
